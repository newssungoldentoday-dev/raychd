#!/bin/bash
# ============================================================================
# Ray Chad — pip-install.sh
# Installs Python pip dependencies for Ray Chad
# BlueBixt Developers © 2026
# ============================================================================

GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
MUTED='\033[0;90m'
RESET='\033[0m'

# ── Python pip packages ──
PACKAGES=(
  "requests"
  "websockets"
  "asyncio"
  "cryptography"
  "PyYAML"
  "python-dotenv"
  "colorama"
  "rich"
  "click"
  "paramiko"
  "dnspython"
  "netifaces"
  "psutil"
  "schedule"
  "loguru"
)

TOTAL=${#PACKAGES[@]}
INSTALLED=0
FAILED=0

# ── Bounce Loader ──
bounce_loader() {
  local MESSAGE=$1
  local DURATION=$2
  local WIDTH=24
  local POS=0
  local DIR=1
  local END=$(($(date +%s) + DURATION))

  while [ $(date +%s) -lt $END ]; do
    BAR=""
    for ((i=0; i<WIDTH; i++)); do
      if [ $i -eq $POS ]; then BAR="${BAR}O"
      else BAR="${BAR}-"; fi
    done
    printf "\r  ${CYAN}[${BAR}]${RESET}  ${MESSAGE}"
    POS=$((POS + DIR))
    if [ $POS -ge $((WIDTH - 1)) ]; then DIR=-1; fi
    if [ $POS -le 0 ]; then DIR=1; fi
    sleep 0.07
  done

  DONE_BAR=""
  for ((i=0; i<WIDTH; i++)); do DONE_BAR="${DONE_BAR}─"; done
  printf "\r  ${GREEN}[${DONE_BAR}]${RESET}  ${GREEN}✔ ${MESSAGE}${RESET}\n"
}

# ── Detect OS ──
detect_os() {
  if [ -n "$TERMUX_VERSION" ]; then OS="termux"
  elif [[ "$OSTYPE" == "darwin"* ]]; then OS="macos"
  elif [[ "$OSTYPE" == "linux-gnu"* ]]; then OS="linux"
  else OS="unknown"; fi
}

# ── Check Python & pip ──
check_python() {
  echo ""
  echo -e "  ${YELLOW}Checking Python & pip...${RESET}"

  if ! command -v python3 &>/dev/null; then
    echo -e "  ${RED}✘ Python3 not found. Installing...${RESET}"
    if [ "$OS" == "termux" ]; then
      pkg install -y python
    elif [ "$OS" == "macos" ]; then
      brew install python
    elif [ "$OS" == "linux" ]; then
      sudo apt install -y python3 python3-pip
    fi
  else
    echo -e "  ${GREEN}✔ Python3 found: $(python3 --version)${RESET}"
  fi

  if ! command -v pip3 &>/dev/null && ! command -v pip &>/dev/null; then
    echo -e "  ${RED}✘ pip not found. Installing...${RESET}"
    if [ "$OS" == "termux" ]; then
      pkg install -y python-pip
    elif [ "$OS" == "linux" ]; then
      sudo apt install -y python3-pip
    else
      python3 -m ensurepip --upgrade
    fi
  else
    echo -e "  ${GREEN}✔ pip found: $(pip3 --version 2>/dev/null || pip --version)${RESET}"
  fi
}

# ── Get pip command ──
get_pip() {
  if command -v pip3 &>/dev/null; then
    echo "pip3"
  elif command -v pip &>/dev/null; then
    echo "pip"
  else
    echo ""
  fi
}

# ── Install single package ──
install_package() {
  local PKG=$1
  local PIP=$2

  bounce_loader "Installing $PKG..." 1

  if [ "$OS" == "termux" ]; then
    $PIP install "$PKG" --break-system-packages &>/dev/null
  else
    $PIP install "$PKG" &>/dev/null
  fi

  if [ $? -eq 0 ]; then
    INSTALLED=$((INSTALLED + 1))
  else
    echo -e "  ${RED}✘ Failed to install $PKG${RESET}"
    FAILED=$((FAILED + 1))
  fi
}

# ── Write requirements.txt ──
write_requirements() {
  bounce_loader "Writing requirements.txt..." 1
  cat > requirements.txt << REQEOF
# Ray Chad — requirements.txt
# Auto-generated by pip-install.sh
# BlueBixt Developers © 2026

requests
websockets
asyncio
cryptography
PyYAML
python-dotenv
colorama
rich
click
paramiko
dnspython
netifaces
psutil
schedule
loguru
REQEOF
  echo -e "  ${GREEN}✔ requirements.txt written.${RESET}"
}

# ── Main ──
clear
echo ""
echo -e "${BOLD}${CYAN}  ============================================================${RESET}"
echo -e "${BOLD}${CYAN}   Ray Chad — pip Installer${RESET}"
echo -e "${BOLD}${CYAN}  ============================================================${RESET}"
echo -e "  ${MUTED}BlueBixt Developers © 2026${RESET}"
echo ""
echo -e "  ${YELLOW}${TOTAL} Python packages will be installed:${RESET}"
echo ""
for PKG in "${PACKAGES[@]}"; do
  echo -e "  ${MUTED}•${RESET} $PKG"
done
echo ""

read -p "  Proceed with installation? [y/N]: " CONFIRM
if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
  echo -e "\n  ${YELLOW}Installation cancelled.${RESET}\n"
  exit 0
fi

echo ""
detect_os
echo -e "  ${CYAN}Detected OS:${RESET} $OS"
echo ""

check_python

PIP=$(get_pip)
if [ -z "$PIP" ]; then
  echo -e "  ${RED}✘ pip not available. Please install pip manually.${RESET}"
  exit 1
fi

echo ""
echo -e "  ${YELLOW}Installing packages with $PIP...${RESET}"
echo ""

for PKG in "${PACKAGES[@]}"; do
  install_package "$PKG" "$PIP"
done

write_requirements

echo ""
echo -e "${BOLD}${CYAN}  ============================================================${RESET}"
echo -e "  ${GREEN}${BOLD}✔ ${INSTALLED}/${TOTAL} packages installed!${RESET}"
if [ $FAILED -gt 0 ]; then
  echo -e "  ${RED}✘ ${FAILED} packages failed.${RESET}"
fi
echo -e "${BOLD}${CYAN}  ============================================================${RESET}"
echo ""
echo -e "  ${CYAN}To reinstall anytime:${RESET}"
echo -e "  ${MUTED}$PIP install -r requirements.txt${RESET}"
echo ""



