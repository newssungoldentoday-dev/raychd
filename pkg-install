#!/bin/bash

# Ray Chad IRC Server - Universal Installation Script
# Works on: Termux, macOS, Linux (Debian, Ubuntu, CentOS, Fedora, Arch, Alpine), WSL, and more

set -e

echo "=========================================="
echo "  Ray Chad IRC Server - Installation"
echo "=========================================="
echo "  Welcome to Ray Chad IRC Server Installation"
echo "  Supported Terminal: Termux, Linux (Debian, Ubuntu, CentOS, Fedora, Arch, Alpine), and More"
echo "  Report an Issue in https://github.com/newssungoldentoday-dev/raychd/"
echo "  Ray Chad is Developed By BlueBixt Ltd., or NewsSunGoldenToday BlueBixt Ltd.,"
echo "  Thank You For downloading!"
echo ""

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Detect environment
detect_environment() {
    if [ -n "$TERMUX_VERSION" ]; then
        ENV="termux"
        echo -e "${BLUE}[*] Detected: Termux${NC}"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        ENV="macos"
        echo -e "${BLUE}[*] Detected: macOS${NC}"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        ENV="linux"
        echo -e "${BLUE}[*] Detected: Linux${NC}"
    elif [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]]; then
        ENV="windows"
        echo -e "${BLUE}[*] Detected: Windows (Git Bash/Cygwin)${NC}"
    else
        echo -e "${RED}Unsupported environment: $OSTYPE${NC}"
        exit 1
    fi
}

# Detect Linux distribution
detect_linux_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        DISTRO=$ID
    elif [ -f /etc/lsb-release ]; then
        . /etc/lsb-release
        DISTRO=$(echo $DISTRIB_ID | tr '[:upper:]' '[:lower:]')
    elif [ -f /etc/debian_version ]; then
        DISTRO="debian"
    elif [ -f /etc/redhat-release ]; then
        DISTRO="rhel"
    elif [ -f /etc/arch-release ]; then
        DISTRO="arch"
    elif [ -f /etc/alpine-release ]; then
        DISTRO="alpine"
    else
        DISTRO="unknown"
    fi
    echo -e "${BLUE}[*] Detected Linux Distro: $DISTRO${NC}"
}

# Install dependencies based on environment
install_dependencies() {
    echo -e "${GREEN}[1/5] Installing dependencies...${NC}"
    
    if [ "$ENV" == "termux" ]; then
        echo "Setting up Termux environment..."
        pkg update -y
        pkg install -y build-essential git openssl autoconf automake pkg-config irssi
        pkg install -y clang make
        mkdir -p ~/raychd-repo/dists/stable/main/binary-aarch64/
        cp ~/raychd-irc-1.0.0.deb ~/raychd-repo/dists/stable/main/binary-aarch64/
        pkg install dpkg-dev
        cd ~/raychd-repo
        dpkg-scanpackages dists/stable/main/binary-aarch64/ | gzip -c > dists/stable/main/binary-aarch64/Packages.gz
        echo "deb [trusted=yes] https://newssungoldentoday-dev.github.io/raychd stable main" > $PREFIX/etc/apt/sources.list.d/raychd.list
        pkg update
        pkg install raychd-irc

        
    elif [ "$ENV" == "macos" ]; then
        if ! command -v brew &> /dev/null; then
            echo -e "${YELLOW}Homebrew not found. Installing Homebrew first...${NC}"
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi
        brew update
        brew install autoconf automake openssl git pkg-config
        export LDFLAGS="-L/usr/local/opt/openssl/lib"
        export CPPFLAGS="-I/usr/local/opt/openssl/include"
        
    elif [ "$ENV" == "linux" ]; then
        detect_linux_distro
        
        if [[ "$DISTRO" =~ ^(ubuntu|debian)$ ]]; then
            if [ "$EUID" -ne 0 ]; then
                echo -e "${YELLOW}This requires sudo for Debian/Ubuntu${NC}"
                sudo apt-get update
                sudo apt-get install -y build-essential autoconf automake openssl libssl-dev openssl-dev pkg-config git
            else
                apt-get update
                apt-get install -y build-essential autoconf automake openssl libssl-dev openssl-dev pkg-config git
            fi
        elif [[ "$DISTRO" =~ ^(fedora|rhel|centos)$ ]]; then
            if [ "$EUID" -ne 0 ]; then
                echo -e "${YELLOW}This requires sudo for RHEL/CentOS/Fedora${NC}"
                sudo yum groupinstall -y "Development Tools"
                sudo yum install -y openssl-devel autoconf automake git pkg-config
            else
                yum groupinstall -y "Development Tools"
                yum install -y openssl-devel autoconf automake git pkg-config
            fi
        elif [ "$DISTRO" == "arch" ]; then
            if [ "$EUID" -ne 0 ]; then
                echo -e "${YELLOW}This requires sudo for Arch Linux${NC}"
                sudo pacman -Sy --noconfirm base-devel openssl autoconf automake git pkg-config
            else
                pacman -Sy --noconfirm base-devel openssl autoconf automake git pkg-config
            fi
        elif [ "$DISTRO" == "alpine" ]; then
            if [ "$EUID" -ne 0 ]; then
                echo -e "${YELLOW}This requires sudo for Alpine Linux${NC}"
                sudo apk add --no-cache build-base autoconf automake openssl-dev git pkg-config
            else
                apk add --no-cache build-base autoconf automake openssl-dev git pkg-config
            fi
        else
            echo -e "${YELLOW}Unknown Linux distribution. Trying apt-get...${NC}"
            sudo apt-get update
            sudo apt-get install -y build-essential autoconf automake openssl libssl-dev openssl-dev pkg-config git
        fi
    fi
    
    echo -e "${GREEN}[✓] Dependencies installed${NC}"
    echo ""
}

# Set installation directory
setup_install_dir() {
    if [ "$ENV" == "termux" ]; then
        INSTALL_DIR="${INSTALL_DIR:-$HOME/raychd}"
    else
        INSTALL_DIR="${INSTALL_DIR:-$HOME/raychd}"
    fi
    
    echo -e "${GREEN}[2/5] Setting up installation directory: $INSTALL_DIR${NC}"
    mkdir -p "$INSTALL_DIR"
    cd "$INSTALL_DIR"
    echo -e "${GREEN}[✓] Installation directory ready${NC}"
    echo ""
}

# Clone Ray Chad repository
clone_raychd() {
    echo -e "${GREEN}[3/5] Cloning Ray Chad repository...${NC}"
    
    if [ -d "raychd-repo" ]; then
        echo "Ray Chad repository already exists, updating..."
        cd raychd-repo
        git pull origin main 2>/dev/null || git pull origin master
        cd ..
    else
        git clone https://github.com/newssungoldentoday-dev/raychd.git raychd-repo
    fi
    
    echo -e "${GREEN}[✓] Ray Chad repository ready${NC}"
    echo ""
}

# Build InspIRCd
build_inspircd() {
    echo -e "${GREEN}[4/5] Building InspIRCd...${NC}"
    
    if [ -d "inspircd" ]; then
        echo "InspIRCd already exists, checking for updates..."
        cd inspircd
        git pull 2>/dev/null || true
        cd ..
    else
        echo "Cloning InspIRCd repository..."
        git clone https://github.com/inspircd/inspircd.git
    fi
    
    cd inspircd
    
    echo "Configuring InspIRCd..."
    if [ "$ENV" == "macos" ]; then
        ./configure --prefix="$INSTALL_DIR/inspircd" --enable-gnutls \
            LDFLAGS="-L/usr/local/opt/openssl/lib" \
            CPPFLAGS="-I/usr/local/opt/openssl/include"
    else
        ./configure --prefix="$INSTALL_DIR/inspircd" --enable-gnutls
    fi
    
    echo "Compiling InspIRCd (this may take a few minutes)..."
    make -j$(nproc)
    
    echo "Installing InspIRCd..."
    make install
    
    cd ..
    
    echo -e "${GREEN}[✓] InspIRCd built and installed${NC}"
    echo ""
}

# Deploy configuration
deploy_config() {
    echo -e "${GREEN}[5/5] Deploying Ray Chad configuration...${NC}"
    
    cp raychd-repo/inspircd.conf "$INSTALL_DIR/inspircd/conf/inspircd.conf"
    
    echo -e "${GREEN}[✓] Configuration deployed${NC}"
    echo ""
}

# Create convenience commands
create_shortcuts() {
    echo -e "${GREEN}Creating convenient shortcuts...${NC}"
    
    # Create a wrapper script
    WRAPPER_SCRIPT="$INSTALL_DIR/raychd"
    cat > "$WRAPPER_SCRIPT" << 'WRAPPER_EOF'
#!/bin/bash
INSPIRCD_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/inspircd"
case "$1" in
    start)
        echo "Starting Ray Chad..."
        $INSPIRCD_DIR/bin/inspircd start
        ;;
    stop)
        echo "Stopping Ray Chad..."
        $INSPIRCD_DIR/bin/inspircd stop
        ;;
    restart)
        echo "Restarting Ray Chad..."
        $INSPIRCD_DIR/bin/inspircd restart
        ;;
    status)
        $INSPIRCD_DIR/bin/inspircd status
        ;;
    logs)
        tail -f $INSPIRCD_DIR/data/logs/ircd.log
        ;;
    edit)
        ${EDITOR:-nano} $INSPIRCD_DIR/conf/inspircd.conf
        ;;
    *)
        echo "Usage: raychd {start|stop|restart|status|logs|edit}"
        exit 1
        ;;
esac
WRAPPER_EOF
    
    chmod +x "$WRAPPER_SCRIPT"
    
    # Create symbolic link if possible
    if [ -w /usr/local/bin ] && [ "$ENV" != "termux" ]; then
        ln -sf "$WRAPPER_SCRIPT" /usr/local/bin/raychd 2>/dev/null || true
        echo "✓ Command 'raychd' available globally"
    elif [ -w "$HOME/.local/bin" ]; then
        mkdir -p "$HOME/.local/bin"
        ln -sf "$WRAPPER_SCRIPT" "$HOME/.local/bin/raychd" 2>/dev/null || true
        echo "✓ Command 'raychd' available in ~/.local/bin"
    fi
}

# Main installation flow
main() {
    detect_environment
    echo ""
    
    if [ "$ENV" != "termux" ] && [ "$ENV" != "macos" ] && [ "$EUID" -eq 0 ] && [ "$ENV" == "linux" ]; then
        echo -e "${YELLOW}⚠️  Warning: Running as root. It's safer to run as regular user.${NC}"
        read -p "Continue anyway? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    
    install_dependencies
    setup_install_dir
    clone_raychd
    build_inspircd
    deploy_config
    create_shortcuts
    
    # Display completion message
    echo "=========================================="
    echo -e "${GREEN}  ✓ Installation Complete!${NC}"
    echo "=========================================="
    echo ""
    echo "Ray Chad is installed at: $INSTALL_DIR"
    echo ""
    echo -e "${YELLOW}Quick Start:${NC}"
    echo ""
    echo "1. Edit configuration:"
    echo "   $INSTALL_DIR/raychd edit"
    echo ""
    echo "2. Start the server:"
    echo "   $INSTALL_DIR/raychd start"
    echo ""
    echo "3. Check status:"
    echo "   $INSTALL_DIR/raychd status"
    echo ""
    echo "4. View logs:"
    echo "   $INSTALL_DIR/raychd logs"
    echo ""
    echo "5. Connect with IRC client:"
    echo "   Server: localhost (or your server IP)"
    echo "   Port: 6667 (unencrypted) or 6697 (SSL/TLS)"
    echo "   Default channels: #general, #dev"
    echo ""
    echo -e "${BLUE}Documentation:${NC}"
    echo "  Quick Start: $INSTALL_DIR/raychd-repo/QUICK_START.md"
    echo "  Full Guide: $INSTALL_DIR/raychd-repo/GETTING_STARTED.md"
    echo "  Requirements: $INSTALL_DIR/raychd-repo/REQUIREMENTS.txt"
    echo ""
    echo -e "${GREEN}Happy chatting! 🎉${NC}"
    echo ""
}

# Run main function
main
